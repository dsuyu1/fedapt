    # Copy this file to `.env` and fill in your values.
# The notebooks auto-load `.env` (see the bootstrap cell). Real environment
# variables always take precedence over this file. `.env` is gitignored.

# NVD API key — register free at https://nvd.nist.gov/developers/request-an-api-key
# Raises the rate limit from ~5 to ~50 requests / 30s in 0_collection.
NVD_API_KEY=

# Where the corpus / adapters / results live.
#   Colab:  leave blank -> defaults to /content/drive/MyDrive/FedDAPT
#   Remote/local: point at your data dir, e.g. /data/fedapt
FEDDAPT_ROOT=

# Fast scratch dir for training temp files (defaults to the system temp dir).
FEDDAPT_WORK=
